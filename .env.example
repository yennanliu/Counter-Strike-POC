# ── Counter-Strike server config ───────────────────────────────────────────
# Copy to .env for local dev. Prod values come from SSM / Secrets Manager.

NODE_ENV=development

# Game server
PORT=2567

# Database: local dev uses SQLite (a file); prod uses RDS Postgres.
#   local:  sqlite:./data/dev.db
#   prod:   postgres://user:pass@host:5432/cs
DB_URL=sqlite:./data/dev.db

# Replay blob storage: local dev uses a folder; prod uses S3.
#   local:  file:./data/replays
#   prod:   s3://cs-replays-bucket
REPLAY_STORE=file:./data/replays

# Room presence / scale-out (prod only; left empty = in-process single node)
REDIS_URL=
